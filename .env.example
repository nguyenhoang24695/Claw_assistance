# Copy to .env and fill in real values (.env is gitignored — never committed).
# Or generate it on the server with: bash scripts/04-install-openclaw.sh

# --- ROUTING THROUGH 9ROUTER (this project's dedicated instance) ---
OPENAI_API_BASE=http://localhost:20138/v1
OPENAI_API_KEY=9router_local_secret
OPENAI_MODEL=combo-coding

# --- SECURITY & TELEGRAM CHANNEL ---
TELEGRAM_BOT_TOKEN=<token_from_botfather>
TELEGRAM_ALLOWED_USER_IDS=<your_telegram_user_id>

# --- LINUX TERMINAL EXECUTION PERMISSION ---
WORKSPACE_DIR=./workspace
ENABLE_TERMINAL_EXECUTION=true
EXECUTION_MODE=docker
