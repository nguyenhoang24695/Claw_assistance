# Copy to .env and fill in (.env is gitignored). Or: bash scripts/04-make-env.sh
# LLM + Telegram routing live in core/openclaw/config/openclaw.json5;
# these are the runtime secrets it references.

TELEGRAM_BOT_TOKEN=<token_from_botfather>
ROUTER9_API_KEY=<9router_access_key>
# OPENCLAW_GATEWAY_TOKEN is auto-generated by scripts/04-make-env.sh if unset
