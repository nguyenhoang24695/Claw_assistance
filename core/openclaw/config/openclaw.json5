{
  // Gateway runs in local single-host mode (no remote control plane / token).
  // Without this the gateway crash-loops with "Missing config / set gateway.mode=local".
  gateway: {
    mode: "local",
    bind: "lan",
    controlUi: { allowedOrigins: ["http://localhost:18789", "http://127.0.0.1:18789"] },
  },

  // Custom OpenAI-compatible provider → our 9Router instance on the host.
  // From inside the container the host is reachable as host.docker.internal.
  models: {
    mode: "merge",
    providers: {
      router9: {
        baseUrl: "http://host.docker.internal:20138/v1",
        apiKey: "${ROUTER9_API_KEY}",   // real 9Router key (remote access needs auth); set in .env
        api: "openai-completions",
        models: [
          { id: "combo-orchestrator", name: "Task Orchestrator", contextWindow: 128000, maxTokens: 8192 },
          { id: "combo-planner",      name: "Planner / Spec Writer", contextWindow: 128000, maxTokens: 8192 },
          { id: "combo-coder",        name: "Code Implementer", contextWindow: 128000, maxTokens: 8192 },
        ],
      },
    },
  },

  // 3-agent chain:
  // - main/Cua talks to Telegram and only orchestrates task flow.
  // - planner writes specs/plans.
  // - coder implements code from the plan.
  // ponytail: this is the max useful depth; OpenClaw subagents are limited at leaf depth.
  // If planner cannot spawn coder reliably, fallback workflow: planner returns plan to main,
  // then main spawns coder with the plan.
  agents: {
    defaults: { model: { primary: "router9/combo-orchestrator" } },
    list: [
      { id: "main", default: true, name: "Cua",
        model: { primary: "router9/combo-orchestrator" },
        // Cua orchestrates sequentially: spawn planner first, then spawn coder with planner's plan.
        // Do NOT rely on planner spawning coder; OpenClaw strips spawn tools inside subagents.
        subagents: { allowAgents: ["planner", "coder"], requireAgentId: true } },
      { id: "planner", name: "Planner",
        model: { primary: "router9/combo-planner" } },
      { id: "coder", name: "Coder",
        model: { primary: "router9/combo-coder" } },
    ],
  },

  // exec config is top-level (tools.exec.*). agents.defaults does NOT accept a
  // `tools` key — per-agent tool profiles go in agents.list[].tools instead.
  tools: {
    exec: { host: "gateway", security: "full", ask: "off", timeoutSec: 120 },
  },

  // Telegram: single-owner bot. Token comes from .env (TELEGRAM_BOT_TOKEN).
  // allowlist + numeric id => only you can DM it.
  channels: {
    telegram: {
      enabled: true,
      dmPolicy: "allowlist",
      allowFrom: ["6302853216"],
    },
  },
}
